{
  "name": "centralcontext-root",
  "version": "1.0.0",
  "description": "Shared context and logging hub for AI Agents (ChatGPT, Gemini, Antigravity, OpenClaw, Hermes)",
  "private": true,
  "scripts": {
    "setup": "node scripts/generate-token.js && npm run setup:server && npm run setup:cli && node scripts/init-folders.js",
    "setup:server": "npm install --prefix apps/server",
    "setup:cli": "npm install --prefix apps/cli",
    "dev": "npm run dev --prefix apps/server",
    "curate:daily": "npm run curate:daily --prefix apps/cli",
    "sync:push": "npm run sync:push --prefix apps/cli",
    "sync:pull": "npm run sync:pull --prefix apps/cli",
    "capture:start": "node scripts/capture-start.js",
    "capture:files": "npm run capture:files --prefix apps/cli",
    "capture:clipboard": "npm run capture:clipboard --prefix apps/cli",
    "capture:cline": "npm run capture:cline --prefix apps/cli --",
    "cc:terminal": "npm run capture:terminal --prefix apps/cli --",
    "capture:doctor": "node scripts/capture-doctor.js",
    "capture:test": "node scripts/capture-test.js",
    "test:redactor": "node scripts/test-secret-redactor.js",
    "test:recall": "node scripts/test-recall-engine.js",
    "test:context-injection": "node scripts/test-context-injection.js",
    "test:memory-promotion": "node scripts/test-memory-promotion.js",
    "test:recall-eval": "node scripts/test-recall-eval.js",
    "test:recall-eval:self": "node scripts/test-recall-eval.js --self-test",
    "founder:startup": "node scripts/generate-founder-startup-pack.js",
    "test:founder-startup": "node scripts/test-founder-startup-pack.js",
    "daily:digest": "node scripts/generate-daily-digest.js",
    "test:daily-digest": "node scripts/test-daily-digest.js",
    "context:pack": "node scripts/context-pack.js",
    "context:copy": "node scripts/context-pack.js | pbcopy && echo 'CentralContext Pack copied to clipboard'",
    "memory:distill": "node scripts/memory-distill.js",
    "memory:critic": "node scripts/memory-critic.js",
    "memory:judge": "node scripts/founder-judge.js",
    "memory:ai-judge": "node scripts/memory-ai-judge.js",
    "memory:consensus": "node scripts/memory-consensus.js",
    "memory:decay": "node scripts/memory-decay.js",
    "recall:index": "node scripts/recall-index.js",
    "recall:embed": "node scripts/recall-embed.js",
    "recall:rebuild": "node scripts/recall-rebuild.js",
    "reality:scan": "node scripts/reality-scanner.js",
    "memory:pipeline": "node scripts/reality-scanner.js && node scripts/memory-distill.js && node scripts/memory-critic.js && node scripts/founder-judge.js && node scripts/memory-ai-judge.js && node scripts/memory-consensus.js"
  },
  "keywords": [
    "ai",
    "agents",
    "context",
    "knowledge",
    "synchronization"
  ],
  "author": "CentralContext Team",
  "license": "MIT"
}
