# ==========================================
# CentralContext MVP Configuration Example
# Copy this file to .env and configure values.
# ==========================================

# Server Port
PORT=3000

# Environment (development | production)
NODE_ENV=development

# Security API Token (Must be 48 to 64 character secure random string)
# You can generate one using: node scripts/generate-token.js
CENTRAL_CONTEXT_API_KEY=YOUR_SECURE_48_TO_64_CHAR_API_KEY_HERE_EXACTLY

# SQLite Cache Database Location
DB_PATH=data/centralcontext.db

# VPS sync endpoints (Used by local CLI for sync actions)
VPS_URL=https://www.aipilot.vn/centralcontext
# VPS_URL=http://localhost:3000 # (for local dry run testing)

# ==========================================
# Capture Layer configurations
# ==========================================
# Paths to monitor (comma-separated, absolute or relative to workspace root)
WATCH_PATHS=/Users/tuoaoa/Tuoaoa/devflow

# Custom redaction patterns (comma-separated regular expressions)
REDACT_PATTERNS=
